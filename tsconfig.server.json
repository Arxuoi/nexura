{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler", 
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@contracts/*": ["./contracts/*"],
      "@db/*": ["./db/*"],
      "@api/*": ["./api/*"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["api/**/*", "contracts/**/*", "db/**/*"]
}
